{
	"name": "inventory-mobile",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "NODE_OPTIONS='--max-old-space-size=4096' vite dev",
		"build": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"cap:sync": "npm run build && cap sync",
		"cap:ios": "npm run build && cap sync ios && cap open ios",
		"cap:android": "npm run build && cap sync android && cap open android"
	},
	"devDependencies": {
		"@capacitor/cli": "^7.6.7",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/papaparse": "^5.3.16",
		"@vitest/coverage-v8": "^3.2.6",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.5",
		"vite-plugin-devtools-json": "^0.1.0",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@capacitor/android": "^7.6.7",
		"@capacitor/core": "^7.6.7",
		"@capacitor/ios": "^7.6.7",
		"@zxing/browser": "^0.1.5",
		"@zxing/library": "^0.21.3",
		"dexie": "^4.0.11",
		"papaparse": "^5.5.3",
		"quagga": "^0.12.1",
		"svelte-preprocess": "^6.0.3"
	}
}
