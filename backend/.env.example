# Port the server listens on (Render sets PORT automatically).
PORT=8000

# Demo login credentials accepted by /login and /api/login.
DEMO_EMAIL=admin@example.com
DEMO_PASSWORD=password

# Comma-separated list of allowed browser origins (CORS). Leave empty to reflect
# the request origin (handy for local dev). In production set your frontend URL(s):
#   CORS_ORIGINS=https://your-frontend.example,capacitor://localhost,https://localhost
CORS_ORIGINS=
