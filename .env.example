# Convex deployment URL (the online store). Get this by running `npx convex dev`,
# which provisions a deployment and prints the URL (looks like
# https://<name>-<id>.convex.cloud). It's also written to .env.local automatically.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

